            "message": "Angular is running"
          },
          "endsPattern": ".+"
        }
      }
    },
    {
      "type": "npm",
      "script": "test",
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "message": "Karma has started"
          },
          "endsPattern": ".+"
        }
      }
    }
  ]
}
